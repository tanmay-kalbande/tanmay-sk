{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/|assets/|favicon\\.svg|library/).*)",
      "destination": "/index.html"
    },
    { "source": "/library",            "destination": "/index.html" },
    { "source": "/library/book/:slug", "destination": "/index.html" }
  ]
}


